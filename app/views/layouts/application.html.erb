<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <title>WeCare Insights</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer">
    <style>
      :root{
        --primary:#2C3E51; --primary-hover:#182738; --secondary:#F4AE00;
        --green:#22b393; --tiffany:#9AF0C7;
        --bg:#FAFAFA; --card:#fff; --border:#E3E5E8; --text:#2C3E51; --muted:#787D87;
        --success:#48AB7F; --danger:#E94044;
        --radius:8px; --shadow:0 .75rem 1.5rem rgba(18,38,63,.03);
      }
      *{box-sizing:border-box;}
      body{margin:0;font-family:'Poppins',sans-serif;background:var(--bg);color:var(--text);font-size:15px;}
      a{color:inherit;text-decoration:none;}

      /* Sidebar */
      .sidebar{position:fixed;top:0;left:0;width:260px;height:100vh;background:#fff;box-shadow:0 3px 12px #91919166;
        display:flex;flex-direction:column;z-index:1020;overflow-y:auto;}
      .sidebar__brand{display:flex;align-items:center;gap:10px;padding:24px 24px 16px;font-weight:700;font-size:18px;}
      .sidebar__brand .dot{width:12px;height:12px;border-radius:50%;background:var(--tiffany);}
      .sidebar hr{border:0;border-top:1px solid var(--border);margin:8px 20px 12px;}
      .sidebar__nav{list-style:none;padding:0;margin:0;flex:1;}
      .sidebar__nav a{display:flex;align-items:center;gap:12px;padding:12px 24px;color:#919191;font-weight:500;
        border-left:4px solid transparent;transition:.2s;}
      .sidebar__nav a .ico{width:22px;text-align:center;font-size:18px;}
      .sidebar__nav a:hover{color:var(--primary);}
      .sidebar__nav a.active{color:var(--primary);font-weight:600;border-left-color:var(--primary);
        background:rgba(44,62,81,.08);}
      .sidebar__footer{padding:16px 24px;border-top:1px solid var(--border);font-size:12px;color:var(--muted);}
      .sidebar__footer a{color:var(--primary);font-weight:600;}

      /* Main */
      main{margin-left:260px;padding:28px 32px;}
      .page-header{margin-bottom:24px;}
      .page-header .eyebrow{text-transform:uppercase;letter-spacing:.5px;font-size:12px;color:var(--muted);font-weight:600;}
      .page-header h1{font-size:2rem;font-weight:600;margin:2px 0 0;line-height:1.2;}
      .page-header .sub{color:var(--muted);font-size:14px;margin-top:4px;}

      /* Cards */
      .card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);box-shadow:var(--shadow);padding:1.5rem;}
      .grid{display:grid;gap:16px;}
      .kpis{grid-template-columns:repeat(auto-fit,minmax(180px,1fr));}
      .kpi{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);box-shadow:var(--shadow);
        padding:18px 20px;border-top:3px solid var(--tiffany);}
      .kpi .label{font-size:12px;color:var(--muted);}
      .kpi .value{font-size:26px;font-weight:700;margin-top:4px;color:var(--primary);line-height:1.15;overflow-wrap:anywhere;}
      .kpi .info{cursor:help;color:var(--muted);font-size:12px;border:1px solid var(--border);border-radius:50%;width:15px;height:15px;display:inline-flex;align-items:center;justify-content:center;line-height:1;}
      th .info{cursor:help;color:var(--muted);font-size:11px;}

      /* Tabs */
      .tabs{display:flex;gap:0;border-bottom:1px solid rgba(120,125,135,.2);margin-bottom:22px;}
      .tabs button{background:none;border:0;padding:14px 0;margin-right:28px;color:#494F55;font-family:inherit;font-size:15px;
        cursor:pointer;border-bottom:3px solid transparent;}
      .tabs button.active{color:var(--primary);font-weight:600;border-bottom-color:var(--primary);}

      /* Filters */
      .filters{display:flex;gap:14px;align-items:flex-end;flex-wrap:wrap;margin-bottom:22px;}
      .filters label{display:flex;flex-direction:column;font-size:12px;color:var(--muted);gap:5px;}
      .filters input,.filters select{padding:9px 10px;border:1px solid var(--border);border-radius:8px;font-family:inherit;font-size:14px;background:#fff;}
      .btn{background:var(--primary);color:#fff;border:0;padding:10px 18px;border-radius:8px;cursor:pointer;font-family:inherit;font-size:14px;font-weight:500;}
      .btn:hover{background:var(--primary-hover);}
      .btn-outline{background:#fff;color:var(--primary);border:1px solid var(--primary);}
      .btn-outline:hover{background:var(--primary);color:#fff;}
      .link-remove{background:none;border:0;color:var(--muted);cursor:pointer;font-size:14px;padding:4px 8px;border-radius:6px;}
      .link-remove:hover{background:#fdecec;color:var(--danger);}
      .btn-sm{padding:6px 12px;font-size:13px;}

      /* Multi-select empresas */
      .ms{position:relative;}
      .ms__toggle{min-width:220px;text-align:left;background:#fff;border:1px solid var(--border);border-radius:8px;padding:9px 10px;cursor:pointer;font-family:inherit;font-size:14px;color:var(--text);}
      .ms__panel{position:absolute;top:calc(100% + 4px);left:0;z-index:30;background:#fff;border:1px solid var(--border);border-radius:8px;
        box-shadow:0 8px 24px rgba(0,0,0,.08);padding:8px;min-width:240px;max-height:260px;overflow:auto;display:none;}
      .ms.open .ms__panel{display:block;}
      .ms__panel label{display:flex;flex-direction:row;align-items:center;gap:8px;padding:6px 8px;font-size:14px;color:var(--text);border-radius:6px;cursor:pointer;white-space:nowrap;}
      .ms__panel label input{margin:0;flex:0 0 auto;}
      .ms__panel label:hover{background:#f5f7fa;}
      .ms__actions{display:flex;gap:12px;padding:6px 8px 8px;border-bottom:1px solid var(--border);margin-bottom:4px;position:sticky;top:0;background:#fff;}
      .ms__actions button{background:none;border:0;color:var(--primary);cursor:pointer;font-size:12px;font-weight:600;padding:0;}
      .ms__actions button:hover{text-decoration:underline;}

      /* Tables */
      table{width:100%;border-collapse:collapse;background:var(--card);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;box-shadow:var(--shadow);}
      th,td{text-align:left;padding:11px 14px;border-bottom:1px solid #eef1f5;font-size:14px;}
      th{background:#f7f9fb;color:var(--muted);font-weight:600;}
      tr:last-child td{border-bottom:0;}
      .muted{color:var(--muted);} .err{color:var(--danger);font-size:12px;}
      .section-title{font-size:1.125rem;font-weight:600;margin:26px 0 14px;}
      .chart-wrap{position:relative;height:280px;}

      /* Switch */
      .switch{position:relative;display:inline-block;width:44px;height:24px;}
      .switch input{opacity:0;width:0;height:0;}
      .slider{position:absolute;cursor:pointer;inset:0;background:#cbd2da;border-radius:24px;transition:.2s;}
      .slider:before{content:"";position:absolute;height:18px;width:18px;left:3px;bottom:3px;background:#fff;border-radius:50%;transition:.2s;}
      input:checked + .slider{background:var(--green);}
      input:checked + .slider:before{transform:translateX(20px);}
      .badge{display:inline-block;padding:2px 8px;border-radius:10px;font-size:11px;font-weight:600;background:#eef1f5;color:var(--muted);}
    </style>
  </head>
  <body>
    <% if logged_in? %>
      <aside class="sidebar">
        <div class="sidebar__brand"><span class="dot"></span> WeCare Insights</div>
        <hr>
        <ul class="sidebar__nav">
          <li><a href="/" class="<%= 'active' if controller_name == 'dashboard' %>"><span class="ico"><i class="fa-solid fa-chart-column"></i></span> Dashboard</a></li>
          <li><a href="/empresas" class="<%= 'active' if controller_name == 'manage' %>"><span class="ico"><i class="fa-solid fa-building"></i></span> Empresas</a></li>
          <li><a href="/inteligencia-artificial" class="<%= 'active' if controller_name == 'ai' %>"><span class="ico"><i class="fa-solid fa-robot"></i></span> Inteligência Artificial</a></li>
        </ul>
        <div class="sidebar__footer">
          <div><%= current_user_email %></div>
          <%= button_to 'Sair', logout_path, method: :delete, data: { turbo: false }, class: 'btn btn-sm btn-outline', style: 'margin-top:8px;' %>
        </div>
      </aside>
    <% end %>
    <main style="<%= 'margin-left:0' unless logged_in? %>">
      <%= yield %>
    </main>
  </body>
</html>
