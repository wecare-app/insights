<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <title>WeCare Insights</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer">
    <style>
      :root{
        --ink:#0F2030; --primary:#0F2030; --primary-hover:#0B1826;
        --slate:#3C4C5B; --muted:#5F7080;
        --bg:#F4F7F9; --card:#FFFFFF; --border:#E6ECF1; --line-soft:#EEF3F6;
        --brand:#0FA37F; --brand-deep:#0B7E62; --tiffany:#9AF0C7; --tiffany-wash:#E6FBF1;
        --secondary:#E7A93B; --amber:#E7A93B; --green:#0FA37F;
        --danger:#E5484D; --success:#0FA37F;
        --radius:14px; --radius-sm:10px;
        --shadow:0 1px 2px rgba(15,32,48,.05),0 6px 20px -12px rgba(15,32,48,.14);
      }
      *{box-sizing:border-box;}
      body{margin:0;font-family:'Poppins',sans-serif;background:var(--bg);color:var(--ink);font-size:14px;-webkit-font-smoothing:antialiased;}
      a{color:inherit;text-decoration:none;}

      /* Sidebar (dark) */
      .sidebar{position:fixed;top:0;left:0;width:248px;height:100vh;
        background:linear-gradient(180deg,#0F2030,#123047);color:#B7C7D3;
        display:flex;flex-direction:column;z-index:1020;overflow-y:auto;padding:20px 14px;gap:22px;}
      .sidebar__brand{display:flex;align-items:center;gap:11px;padding:2px 6px;}
      .sidebar__brand .mark{width:32px;height:32px;border-radius:9px;flex:none;
        background:linear-gradient(135deg,var(--tiffany),var(--brand));display:grid;place-items:center;
        color:#08251C;font-weight:800;font-size:16px;}
      .sidebar__brand .name{font-weight:700;color:#fff;font-size:15px;letter-spacing:-.01em;line-height:1.1;}
      .sidebar__brand .name span{display:block;font-size:11px;font-weight:500;color:#7C93A5;letter-spacing:.04em;}
      .sidebar__nav{list-style:none;padding:0;margin:0;flex:1;display:flex;flex-direction:column;gap:2px;}
      .sidebar__nav .group{font-size:10.5px;letter-spacing:.13em;text-transform:uppercase;color:#5E7688;margin:12px 8px 6px;}
      .sidebar__nav a{display:flex;align-items:center;gap:12px;padding:10px 12px;color:#B7C7D3;font-weight:500;
        border-radius:9px;transition:background .15s,color .15s;}
      .sidebar__nav a .ico{width:18px;text-align:center;font-size:15px;}
      .sidebar__nav a:hover{background:rgba(255,255,255,.06);color:#EAF2F7;}
      .sidebar__nav a.active{background:rgba(154,240,199,.14);color:#fff;font-weight:600;}
      .sidebar__nav a.active .ico{color:var(--tiffany);}
      .sidebar__footer{padding:14px 10px 4px;border-top:1px solid rgba(255,255,255,.08);font-size:12px;color:#7C93A5;}
      .sidebar__footer a,.sidebar__footer .btn{color:#B7C7D3;}

      /* Main */
      main{margin-left:248px;padding:26px 30px 46px;}
      .page-header{margin-bottom:20px;}
      .page-header .eyebrow{text-transform:uppercase;letter-spacing:.14em;font-size:11px;color:var(--muted);font-weight:600;}
      .page-header h1{font-size:26px;font-weight:700;letter-spacing:-.02em;margin:3px 0 0;line-height:1.15;}
      .page-header .sub{color:var(--muted);font-size:13.5px;margin-top:5px;max-width:64ch;}

      /* Cards / panels */
      .card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);box-shadow:var(--shadow);padding:18px;}
      .grid{display:grid;gap:14px;}
      .kpis{grid-template-columns:repeat(auto-fit,minmax(176px,1fr));}
      .kpi{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);box-shadow:var(--shadow);
        padding:15px 16px 13px;display:flex;flex-direction:column;gap:9px;transition:transform .14s,box-shadow .16s;}
      .kpi:hover{transform:translateY(-2px);box-shadow:0 2px 4px rgba(15,32,48,.05),0 14px 30px -16px rgba(15,32,48,.26);}
      .kpi .label{font-size:12px;color:var(--muted);font-weight:600;display:flex;align-items:center;gap:5px;}
      .kpi .value{font-size:26px;font-weight:700;letter-spacing:-.02em;line-height:1.05;color:var(--ink);
        font-variant-numeric:tabular-nums;overflow-wrap:anywhere;}
      .kpi .info{cursor:help;color:var(--muted);font-size:9px;border:1px solid var(--border);border-radius:50%;
        width:14px;height:14px;display:inline-flex;align-items:center;justify-content:center;line-height:1;font-style:normal;}
      .kpi .foot{display:flex;align-items:center;justify-content:space-between;gap:8px;margin-top:auto;}
      th .info{cursor:help;color:var(--muted);font-size:10px;font-style:normal;}

      /* delta + sparkline (KPI trend) */
      .delta{font-size:12px;font-weight:700;display:inline-flex;align-items:center;gap:3px;padding:2px 7px;border-radius:999px;font-variant-numeric:tabular-nums;}
      .delta--up{color:var(--brand-deep);background:var(--tiffany-wash);}
      .delta--down{color:#B4262B;background:#FDECEC;}
      .delta--flat{color:var(--slate);background:#EEF3F6;}
      .spark{display:block;}

      /* Tabs */
      .tabs{display:flex;gap:0;border-bottom:1px solid var(--border);margin-bottom:20px;flex-wrap:wrap;}
      .tabs button{background:none;border:0;padding:12px 0;margin-right:26px;color:var(--muted);font-family:inherit;font-size:14px;
        cursor:pointer;border-bottom:2px solid transparent;transition:color .15s;}
      .tabs button:hover{color:var(--ink);}
      .tabs button.active{color:var(--ink);font-weight:600;border-bottom-color:var(--brand);}

      /* Filters */
      .filters{display:flex;gap:12px;align-items:flex-end;flex-wrap:wrap;margin-bottom:20px;
        background:var(--card);border:1px solid var(--border);border-radius:var(--radius);box-shadow:var(--shadow);padding:12px 14px;}
      .filters label{display:flex;flex-direction:column;font-size:10.5px;letter-spacing:.05em;text-transform:uppercase;color:var(--muted);gap:4px;font-weight:600;}
      .filters input,.filters select,.ms__toggle{padding:8px 11px;border:1px solid var(--border);border-radius:9px;font-family:inherit;
        font-size:13px;background:#FBFDFE;color:var(--ink);}
      .filters input:focus,.filters select:focus,.ms__toggle:focus-visible{outline:2px solid var(--brand);outline-offset:1px;border-color:var(--brand);}
      .btn{background:var(--ink);color:#fff;border:0;padding:9px 16px;border-radius:9px;cursor:pointer;font-family:inherit;font-size:13px;font-weight:650;
        transition:transform .12s,box-shadow .15s;}
      .btn:hover{transform:translateY(-1px);box-shadow:0 6px 16px -8px rgba(15,32,48,.5);}
      .btn-outline{background:#fff;color:var(--ink);border:1px solid var(--border);}
      .btn-outline:hover{background:var(--ink);color:#fff;}
      .link-remove{background:none;border:0;color:var(--muted);cursor:pointer;font-size:13px;padding:4px 8px;border-radius:6px;}
      .link-remove:hover{background:#fdecec;color:var(--danger);}
      .btn-sm{padding:6px 12px;font-size:12px;}

      /* Multi-select empresas */
      .ms{position:relative;}
      .ms__toggle{min-width:210px;text-align:left;cursor:pointer;}
      .ms__panel{position:absolute;top:calc(100% + 4px);left:0;z-index:30;background:#fff;border:1px solid var(--border);border-radius:10px;
        box-shadow:0 12px 30px -12px rgba(15,32,48,.28);padding:8px;min-width:240px;max-height:264px;overflow:auto;display:none;}
      .ms.open .ms__panel{display:block;}
      .ms__panel label{display:flex;flex-direction:row;align-items:center;gap:8px;padding:6px 8px;font-size:13px;color:var(--slate);border-radius:7px;cursor:pointer;white-space:nowrap;text-transform:none;letter-spacing:0;font-weight:500;}
      .ms__panel label input{margin:0;flex:0 0 auto;}
      .ms__panel label:hover{background:var(--line-soft);}
      .ms__actions{display:flex;gap:12px;padding:6px 8px 8px;border-bottom:1px solid var(--border);margin-bottom:4px;position:sticky;top:0;background:#fff;}
      .ms__actions button{background:none;border:0;color:var(--brand-deep);cursor:pointer;font-size:12px;font-weight:600;padding:0;}
      .ms__actions button:hover{text-decoration:underline;}

      /* Tables */
      table{width:100%;border-collapse:collapse;background:var(--card);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;box-shadow:var(--shadow);}
      th,td{text-align:left;padding:11px 15px;font-size:13px;}
      th{background:#FAFCFD;color:var(--muted);font-weight:600;font-size:11px;letter-spacing:.05em;text-transform:uppercase;border-bottom:1px solid var(--border);}
      td{border-top:1px solid var(--line-soft);color:var(--slate);}
      tbody tr:first-child td{border-top:0;}
      tbody tr:hover{background:#FAFCFD;}
      td strong{color:var(--ink);font-weight:600;}
      .muted{color:var(--muted);} .err{color:var(--danger);font-size:12px;}
      .section-title{font-size:15px;font-weight:700;letter-spacing:-.01em;margin:24px 0 12px;}
      .chart-wrap{position:relative;height:280px;}

      /* Switch */
      .switch{position:relative;display:inline-block;width:44px;height:24px;}
      .switch input{opacity:0;width:0;height:0;}
      .slider{position:absolute;cursor:pointer;inset:0;background:#cbd2da;border-radius:24px;transition:.2s;}
      .slider:before{content:"";position:absolute;height:18px;width:18px;left:3px;bottom:3px;background:#fff;border-radius:50%;transition:.2s;}
      input:checked + .slider{background:var(--brand);}
      input:checked + .slider:before{transform:translateX(20px);}

      /* Badges / tags */
      .badge{display:inline-flex;align-items:center;gap:5px;padding:3px 9px;border-radius:999px;font-size:11px;font-weight:600;background:var(--line-soft);color:var(--slate);}
      .tag{display:inline-flex;align-items:center;gap:6px;font-size:11.5px;font-weight:650;padding:4px 9px;border-radius:999px;white-space:nowrap;}
      .tag::before{content:"";width:6px;height:6px;border-radius:50%;}
      .tag--crit{color:#B4262B;background:#FDECEC;} .tag--crit::before{background:var(--danger);}
      .tag--warn{color:#8A5A12;background:#FCF3E3;} .tag--warn::before{background:var(--amber);}
      .tag--ok{color:var(--brand-deep);background:var(--tiffany-wash);} .tag--ok::before{background:var(--brand);}

      @media (max-width:820px){ .sidebar{display:none;} main{margin-left:0;} }
      @media (prefers-reduced-motion:reduce){ *{transition:none !important;} }
    </style>
  </head>
  <body>
    <% if logged_in? %>
      <aside class="sidebar">
        <div class="sidebar__brand">
          <span class="mark">W</span>
          <span class="name">WeCare<span>Insights</span></span>
        </div>
        <ul class="sidebar__nav">
          <li><a href="/" class="<%= 'active' if controller_name == 'dashboard' %>"><span class="ico"><i class="fa-solid fa-chart-column"></i></span> Dashboard</a></li>
          <li><a href="/empresas" class="<%= 'active' if controller_name == 'manage' %>"><span class="ico"><i class="fa-solid fa-building"></i></span> Empresas</a></li>
          <li><a href="/inteligencia-artificial" class="<%= 'active' if controller_name == 'ai' %>"><span class="ico"><i class="fa-solid fa-robot"></i></span> Inteligência Artificial</a></li>
        </ul>
        <div class="sidebar__footer">
          <div><%= current_user_email %></div>
          <%= button_to 'Sair', logout_path, method: :delete, data: { turbo: false }, class: 'btn btn-sm btn-outline', style: 'margin-top:8px;' %>
        </div>
      </aside>
    <% end %>
    <main style="<%= 'margin-left:0' unless logged_in? %>">
      <%= yield %>
    </main>
  </body>
</html>
