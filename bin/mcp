#!/usr/bin/env ruby
# frozen_string_literal: true

require_relative '../config/environment'
require 'json'

def emit(payload)
  $stdout.puts(JSON.generate(payload))
  $stdout.flush
end

$stdin.each_line do |line|
  line = line.strip
  next if line.empty?

  message = begin
    JSON.parse(line)
  rescue JSON::ParserError
    next
  end

  response = Insights::Mcp.handle(message)
  emit(response) unless response.nil?
end
